<Window x:Class="tearhacker7daystodieStarter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="7DayToDieV2.6 Launcher"
        Height="500" Width="760"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        Icon="res/7daystodie.ico"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border CornerRadius="12" Background="#0A0E17" Margin="8">
        <Border.Effect>
            <DropShadowEffect Color="#00E5FF" Opacity="0.15" BlurRadius="30" ShadowDepth="0"/>
        </Border.Effect>

        <Grid>
            <!-- ========================= 主界面 ========================= -->
            <Grid x:Name="MainPanel">
                <!-- 背景呼吸光效 -->
                <Ellipse x:Name="BgGlow" Width="400" Height="400" Opacity="0.3"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#00E5FF" Offset="0"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- ===== 顶部栏 ===== -->
                    <Grid Grid.Row="0" Margin="20,16,20,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo + 标题 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE968;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="#00E5FF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="7DayToDieV2.6" FontSize="16" FontWeight="Bold"
                                       Foreground="#00E5FF" VerticalAlignment="Center"
                                       FontFamily="Consolas"/>
                            <TextBlock Text=" LAUNCHER" FontSize="16" FontWeight="Light"
                                       Foreground="#FFFFFF" Opacity="0.5" VerticalAlignment="Center"
                                       FontFamily="Consolas"/>
                        </StackPanel>

                        <!-- 灵动岛 -->
                        <Border Grid.Column="1" x:Name="DynamicIsland"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                CornerRadius="18" Padding="16,6"
                                Background="#1A1F2E" BorderThickness="1"
                                MinWidth="160">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#00E5FF" Opacity="0.25"/>
                            </Border.BorderBrush>
                            <TextBlock x:Name="StatusText" Text="SYSTEM READY"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#00E5FF" FontFamily="Consolas"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <!-- 语言切换 -->
                        <Button Grid.Column="2" x:Name="LangBtn" Click="LangBtn_Click"
                                Margin="0,0,6,0" Cursor="Hand" VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="4" Padding="10,4"
                                            BorderThickness="1" Background="Transparent">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#00E5FF" Opacity="0.3"/>
                                        </Border.BorderBrush>
                                        <TextBlock x:Name="LangBtnText" Text="中文" FontSize="10" FontWeight="Medium"
                                                   Foreground="#00E5FF" FontFamily="Consolas"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#00E5FF15"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 关闭按钮 -->
                        <Button Grid.Column="3" x:Name="CloseBtn" Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Foreground="#FFFFFF" Opacity="0.4"
                                Background="Transparent" BorderThickness="0"
                                Width="28" Height="28" Cursor="Hand"
                                Click="CloseBtn_Click"
                                VerticalAlignment="Center">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#FF3B3B"/>
                                            <Setter Property="Foreground" Value="White"/>
                                            <Setter Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                    <!-- ===== 中心区域 ===== -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-20,0,0">

                        <!-- 游戏路径显示 -->
                        <Border CornerRadius="8" Background="#1A1F2EE6" Padding="14,10"
                                BorderThickness="1" Margin="0,0,0,16" Width="520">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#00E5FF" Opacity="0.15"/>
                            </Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="14"
                                           Foreground="#00E5FF" VerticalAlignment="Center" Margin="0,0,8,0"/>

                                <TextBlock x:Name="PathText" Grid.Column="1"
                                           Text="" FontSize="12"
                                           Foreground="#FFFFFF" Opacity="0.7" FontFamily="Consolas"
                                           VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                <Button Grid.Column="2" x:Name="BrowseBtn" Content="&#xE8DA;"
                                        FontFamily="Segoe MDL2 Assets" FontSize="12"
                                        Foreground="#00E5FF" Background="Transparent" BorderThickness="0"
                                        Width="28" Height="28" Cursor="Hand" VerticalAlignment="Center"
                                        Click="BrowseBtn_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="#00E5FF20"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Mod 状态 -->
                        <Border x:Name="ModStatusPanel" CornerRadius="8" Background="#1A1F2EE6"
                                Padding="14,8" BorderThickness="1" Margin="0,0,0,20" Width="520">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#00E5FF" Opacity="0.15"/>
                            </Border.BorderBrush>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse x:Name="ModStatusDot" Width="8" Height="8"
                                         Fill="#FF6B6B" VerticalAlignment="Center" Margin="0,0,10,0"/>

                                <TextBlock x:Name="ModStatusText" Grid.Column="1"
                                           Text="" FontSize="12"
                                           Foreground="#FFFFFF" Opacity="0.7" FontFamily="Consolas"
                                           VerticalAlignment="Center"/>

                                <TextBlock x:Name="ModVersionText" Grid.Column="2"
                                           Text="v1.0.0" FontSize="10"
                                           Foreground="#00E5FF" Opacity="0.5" FontFamily="Consolas"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 主按钮 -->
                        <Button x:Name="InstallBtn" Click="InstallBtn_Click"
                                Width="280" Height="56" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="MainBtnBorder" CornerRadius="28"
                                            BorderThickness="1.5" ClipToBounds="True">
                                        <Border.BorderBrush>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#00E5FF" Offset="0"/>
                                                <GradientStop Color="#9D4EDD" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.BorderBrush>
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#00E5FF" Offset="0"/>
                                                <GradientStop Color="#9D4EDD" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="MainBtnBorder" Property="RenderTransform">
                                                <Setter.Value>
                                                    <ScaleTransform ScaleX="1.03" ScaleY="1.03"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="MainBtnBorder" Property="Opacity" Value="0.4"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock x:Name="BtnText" Text="INSTALL MOD"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="#FFFFFF" FontFamily="Consolas"/>
                        </Button>

                        <!-- 进度条 -->
                        <Border x:Name="ProgressPanel" CornerRadius="4" Background="#1A1F2EE6"
                                Width="280" Height="6" Margin="0,12,0,0"
                                Visibility="Collapsed" ClipToBounds="True">
                            <Border x:Name="ProgressFill" CornerRadius="4"
                                    Background="#00E5FF" Width="0"
                                    HorizontalAlignment="Left"/>
                        </Border>

                        <!-- 卸载按钮 -->
                        <Button x:Name="UninstallBtn" Click="UninstallBtn_Click"
                                Width="280" Height="36" Cursor="Hand" Margin="0,12,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="UninstallBtnBorder" CornerRadius="18"
                                            BorderThickness="1" ClipToBounds="True"
                                            Background="Transparent">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#FF6B6B" Opacity="0.5"/>
                                        </Border.BorderBrush>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="UninstallBtnBorder" Property="Background" Value="#FF6B6B18"/>
                                            <Setter TargetName="UninstallBtnBorder" Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#FF6B6B" Opacity="0.8"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="UninstallBtnBorder" Property="Opacity" Value="0.3"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock x:Name="UninstallBtnText" Text="UNINSTALL MOD"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#FF6B6B" FontFamily="Consolas" Opacity="0.7"/>
                        </Button>

                        <!-- 日志输出 -->
                        <TextBlock x:Name="LogText" Text="" FontSize="10"
                                   Foreground="#FFFFFF" Opacity="0.35" FontFamily="Consolas"
                                   HorizontalAlignment="Center" Margin="0,10,0,0"
                                   TextWrapping="Wrap" MaxWidth="500"/>
                    </StackPanel>

                    <!-- ===== 底部栏 ===== -->
                    <Grid Grid.Row="2" Margin="20,0,20,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="v1.0.0" FontSize="10"
                                   Foreground="#FFFFFF" Opacity="0.2" FontFamily="Consolas"
                                   VerticalAlignment="Center"/>

                        <!-- 泪心官网 -->
                        <Button Grid.Column="1" x:Name="WebsiteBtn" Click="WebsiteBtn_Click"
                                Margin="0,0,8,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6" Padding="12,6"
                                            BorderThickness="1" Background="Transparent">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#00E5FF" Opacity="0.4"/>
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       Foreground="#00E5FF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="WebsiteBtnText" Text="WEBSITE" FontSize="11" FontWeight="Medium"
                                                       Foreground="#00E5FF" FontFamily="Consolas"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#00E5FF15"/>
                                            <Setter TargetName="bd" Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#00E5FF" Opacity="0.8"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- GitHub -->
                        <Button Grid.Column="2" x:Name="GithubBtn" Click="GithubBtn_Click"
                                Margin="0,0,8,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6" Padding="12,6"
                                            BorderThickness="1" Background="Transparent">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#9D4EDD" Opacity="0.4"/>
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal">
                                            <Border Width="16" Height="16" CornerRadius="8"
                                                    ClipToBounds="True" VerticalAlignment="Center" Margin="0,0,6,0">
                                                <Image Source="res/githubavatar.ico"
                                                       Width="16" Height="16" Stretch="UniformToFill"/>
                                            </Border>
                                            <TextBlock Text="GitHub" FontSize="11" FontWeight="Medium"
                                                       Foreground="#9D4EDD" FontFamily="Consolas"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#9D4EDD15"/>
                                            <Setter TargetName="bd" Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#9D4EDD" Opacity="0.8"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- 启动游戏 -->
                        <Button Grid.Column="3" x:Name="LaunchBtn" Click="LaunchBtn_Click" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="6" Padding="14,7"
                                            BorderThickness="1" Background="Transparent">
                                        <Border.BorderBrush>
                                            <SolidColorBrush Color="#00E5FF" Opacity="0.4"/>
                                        </Border.BorderBrush>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                                       Foreground="#00E5FF" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock x:Name="LaunchBtnText" Text="LAUNCH GAME" FontSize="11" FontWeight="Medium"
                                                       Foreground="#00E5FF" FontFamily="Consolas"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#00E5FF15"/>
                                            <Setter TargetName="bd" Property="BorderBrush">
                                                <Setter.Value>
                                                    <SolidColorBrush Color="#00E5FF" Opacity="0.8"/>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ========================= 启动游戏覆盖层（科技赛博风） ========================= -->
            <Grid x:Name="LaunchingOverlay" Visibility="Collapsed" Background="#0A0E17">

                <!-- 背景网格线 (cyber grid) -->
                <Canvas x:Name="GridCanvas" IsHitTestVisible="False" Opacity="0.18"/>

                <!-- 中心放射光 -->
                <Ellipse x:Name="LaunchGlow" Width="600" Height="600" Opacity="0.35"
                         HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#00E5FF" Offset="0"/>
                            <GradientStop Color="#9D4EDD" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>

                <!-- 顶部水平扫描线 -->
                <Rectangle x:Name="ScanLine" Height="2" VerticalAlignment="Top"
                           HorizontalAlignment="Stretch" Opacity="0.85" IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="Transparent" Offset="0"/>
                            <GradientStop Color="#00E5FF" Offset="0.5"/>
                            <GradientStop Color="Transparent" Offset="1"/>
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                    <Rectangle.Effect>
                        <BlurEffect Radius="6"/>
                    </Rectangle.Effect>
                    <Rectangle.RenderTransform>
                        <TranslateTransform x:Name="ScanLineTransform" Y="0"/>
                    </Rectangle.RenderTransform>
                </Rectangle>

                <!-- 顶部 HUD 头标 -->
                <Grid VerticalAlignment="Top" Margin="20,16,20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" Fill="#00FF88" Margin="0,0,8,0">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00FF88" BlurRadius="10" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>
                        <TextBlock Text="SYSTEM://CORE" FontSize="11" FontWeight="Medium"
                                   Foreground="#00E5FF" FontFamily="Consolas" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border Grid.Column="1" x:Name="LaunchIsland"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            CornerRadius="18" Padding="22,7"
                            Background="#1A1F2E" BorderThickness="1">
                        <Border.BorderBrush>
                            <SolidColorBrush Color="#00E5FF" Opacity="0.45"/>
                        </Border.BorderBrush>
                        <Border.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="22" ShadowDepth="0" Opacity="0.6"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="LaunchIslandDot" Width="8" Height="8" Fill="#00E5FF"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="LaunchIslandText" Text="GAME LAUNCHING"
                                       FontSize="11" FontWeight="Medium"
                                       Foreground="#00E5FF" FontFamily="Consolas"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="LaunchClock" Grid.Column="2" Text="00:00"
                               FontSize="11" FontFamily="Consolas"
                               Foreground="#00E5FF" Opacity="0.7" VerticalAlignment="Center"/>
                </Grid>

                <!-- 中央：雷达 + 主标题 -->
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 雷达圆环 + 旋转射线 -->
                    <Grid Grid.Row="0" Width="220" Height="220" HorizontalAlignment="Center">
                        <!-- 外环 -->
                        <Ellipse Width="220" Height="220" Stroke="#00E5FF" StrokeThickness="1" Opacity="0.35"/>
                        <Ellipse Width="170" Height="170" Stroke="#00E5FF" StrokeThickness="1" Opacity="0.25"
                                 StrokeDashArray="2 4"/>
                        <Ellipse Width="120" Height="120" Stroke="#00E5FF" StrokeThickness="1" Opacity="0.2"/>
                        <Ellipse Width="70" Height="70" Stroke="#9D4EDD" StrokeThickness="1" Opacity="0.4"
                                 StrokeDashArray="3 3"/>

                        <!-- 十字准星 -->
                        <Line X1="-110" Y1="0" X2="110" Y2="0" Stroke="#00E5FF" StrokeThickness="0.5"
                              Opacity="0.2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Line X1="0" Y1="-110" X2="0" Y2="110" Stroke="#00E5FF" StrokeThickness="0.5"
                              Opacity="0.2" HorizontalAlignment="Center" VerticalAlignment="Center"/>

                        <!-- 旋转射线 (扇形) -->
                        <Grid Width="220" Height="220" RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <RotateTransform x:Name="RadarRotate" Angle="0"/>
                            </Grid.RenderTransform>
                            <Path Stroke="Transparent">
                                <Path.Fill>
                                    <RadialGradientBrush Center="0.5,0.5" GradientOrigin="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                                        <GradientStop Color="#9000E5FF" Offset="0"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </RadialGradientBrush>
                                </Path.Fill>
                                <Path.Data>
                                    <PathGeometry>
                                        <PathFigure StartPoint="110,110">
                                            <LineSegment Point="220,110"/>
                                            <ArcSegment Point="195,30" Size="110,110"
                                                        SweepDirection="Counterclockwise" IsLargeArc="False"/>
                                            <LineSegment Point="110,110"/>
                                        </PathFigure>
                                    </PathGeometry>
                                </Path.Data>
                            </Path>
                            <!-- 主射线 -->
                            <Line X1="110" Y1="110" X2="220" Y2="110"
                                  Stroke="#00E5FF" StrokeThickness="1.5" Opacity="0.9">
                                <Line.Effect>
                                    <DropShadowEffect Color="#00E5FF" BlurRadius="8" ShadowDepth="0"/>
                                </Line.Effect>
                            </Line>
                        </Grid>

                        <!-- 中心点 -->
                        <Ellipse Width="10" Height="10" Fill="#00E5FF">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="#00E5FF" BlurRadius="14" ShadowDepth="0"/>
                            </Ellipse.Effect>
                        </Ellipse>

                        <!-- 角标 -->
                        <Path Stroke="#00E5FF" StrokeThickness="1.2" Opacity="0.7"
                              HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-10,-10,0,0"
                              Data="M 0 14 L 0 0 L 14 0"/>
                        <Path Stroke="#00E5FF" StrokeThickness="1.2" Opacity="0.7"
                              HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"
                              Data="M 14 14 L 14 0 L 0 0"/>
                        <Path Stroke="#00E5FF" StrokeThickness="1.2" Opacity="0.7"
                              HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-10,0,0,-10"
                              Data="M 0 0 L 0 14 L 14 14"/>
                        <Path Stroke="#00E5FF" StrokeThickness="1.2" Opacity="0.7"
                              HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-10,-10"
                              Data="M 14 0 L 14 14 L 0 14"/>
                    </Grid>

                    <!-- 主标题 -->
                    <TextBlock Grid.Row="1" x:Name="LaunchTitle" Text="GAME IS LAUNCHING"
                               FontSize="28" FontWeight="Bold" FontFamily="Consolas"
                               Foreground="#FFFFFF" HorizontalAlignment="Center" Margin="0,28,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00E5FF" BlurRadius="18" ShadowDepth="0" Opacity="0.85"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- 副标题（带光标） -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
                        <TextBlock x:Name="LaunchSubtitle" Text="正在唤醒游戏进程"
                                   FontSize="12" FontFamily="Consolas"
                                   Foreground="#00E5FF" Opacity="0.85"/>
                        <TextBlock x:Name="LaunchDots" Text="..." FontSize="12" FontFamily="Consolas"
                                   Foreground="#00E5FF" Opacity="0.85"/>
                        <Rectangle x:Name="Caret" Width="7" Height="13" Fill="#00E5FF"
                                   Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 进度条 + 百分比 -->
                    <Grid Grid.Row="3" Margin="0,28,0,0" Width="380">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="2" Background="#1A1F2E" Height="3"
                                ClipToBounds="True">
                            <Border x:Name="LaunchProgressFill" CornerRadius="2"
                                    HorizontalAlignment="Left" Width="0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#00E5FF" Offset="0"/>
                                        <GradientStop Color="#9D4EDD" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <Border.Effect>
                                    <DropShadowEffect Color="#00E5FF" BlurRadius="8" ShadowDepth="0"/>
                                </Border.Effect>
                            </Border>
                        </Border>
                        <Grid Grid.Row="1" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" x:Name="LaunchStageText" Text="[ STAGE 1/4 ] BOOT SEQUENCE"
                                       FontSize="10" FontFamily="Consolas"
                                       Foreground="#FFFFFF" Opacity="0.5"/>
                            <TextBlock Grid.Column="1" x:Name="LaunchPercentText" Text="0%"
                                       FontSize="10" FontFamily="Consolas"
                                       Foreground="#00E5FF" Opacity="0.9"/>
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 底部代码流日志 -->
                <Border VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
                        Margin="20,0,20,18" CornerRadius="6"
                        Background="#1A1F2E80" BorderThickness="1" Padding="14,8">
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#00E5FF" Opacity="0.18"/>
                    </Border.BorderBrush>
                    <StackPanel>
                        <TextBlock x:Name="LogLine1" Text="" FontSize="10" FontFamily="Consolas"
                                   Foreground="#00E5FF" Opacity="0.45"/>
                        <TextBlock x:Name="LogLine2" Text="" FontSize="10" FontFamily="Consolas"
                                   Foreground="#00E5FF" Opacity="0.65"/>
                        <TextBlock x:Name="LogLine3" Text="" FontSize="10" FontFamily="Consolas"
                                   Foreground="#00E5FF" Opacity="0.95"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
