    <append xpath="/entity_classes/entity_class[@name='npcTraderJoel']">
        <property name="NavObject" value="RadarNPC" />
    </append>

    <append xpath="/entity_classes/entity_class[@name='npcTraderHugh']">
        <property name="NavObject" value="RadarNPC" />
