    <!-- NPC (商人) 蓝色 -->
    <append xpath="/nav_object_classes">
        <nav_object_class name="RadarNPC">
            <map_settings>
                <property name="sprite_name" value="ui_game_symbol_trader" />
                <property name="min_distance" value="0" />
                <property name="max_distance" value="-1" />
                <property name="color" value="100,180,255,255" />
            </map_settings>
            <compass_settings>
                <property name="sprite_name" value="ui_game_symbol_trader" />
                <property name="color" value="100,180,255,255" />
                <property name="icon_clamped" value="false" />
                <property name="min_distance" value="0" />
                <property name="max_distance" value="-1" />
            </compass_settings>
            <onscreen_settings>
                <property name="sprite_name" value="ui_game_symbol_trader" />
                <property name="color" value="100,180,255,255" />
                <property name="offset" value="0,2.5,0" />
                <property name="min_distance" value="1" />
                <property name="max_distance" value="300" />
                <property name="text_type" value="Distance" />
                <property name="font_size" value="22" />
                <property name="font_color" value="180,220,255,255" />
                <property name="sprite_size" value="36" />
                <property name="show_offscreen" value="true" />
            </onscreen_settings>
        </nav_object_class>
    </append>

</configs>
