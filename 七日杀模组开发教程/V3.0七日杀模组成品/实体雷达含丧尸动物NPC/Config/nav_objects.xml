            </compass_settings>
            <onscreen_settings>
                <property name="sprite_name" value="ui_game_symbol_enemy_blip" />
                <property name="color" value="255,255,0,255" />
                <property name="offset" value="0,1.5,0" />
                <property name="has_pulse" value="true" />
                <property name="min_distance" value="1" />
                <property name="max_distance" value="150" />
                <property name="text_type" value="Distance" />
                <property name="font_size" value="20" />
                <property name="font_color" value="255,255,200,255" />
                <property name="sprite_size" value="32" />
                <property name="show_offscreen" value="true" />
            </onscreen_settings>
