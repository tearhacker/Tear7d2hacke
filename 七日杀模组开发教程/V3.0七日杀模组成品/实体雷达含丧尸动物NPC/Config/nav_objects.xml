<configs>
    <!-- ============================================ -->
    <!--  雷达图标样式定义 (V3.0完整修复版)                 -->
    <!--  V3.0属性变更:                                  -->
    <!--    - show_distance → text_type="Distance"      -->
    <!--    - 新增 sprite_size / font_size 控制          -->
    <!--  ============================================ -->

    <!-- 敌对实体 (僵尸) 红色脉冲 -->
    <append xpath="/nav_object_classes">
        <nav_object_class name="RadarEnemy">
            <map_settings>
                <property name="sprite_name" value="ui_game_symbol_enemy_blip" />
                <property name="min_distance" value="0" />
                <property name="max_distance" value="-1" />
                <property name="color" value="255,50,50,255" />
                <property name="has_pulse" value="true" />
            </map_settings>
            <compass_settings>
                <property name="sprite_name" value="ui_game_symbol_zombie" />
                <property name="color" value="255,50,50,255" />
                <property name="has_pulse" value="true" />
                <property name="icon_clamped" value="true" />
                <property name="min_distance" value="0" />
                <property name="max_distance" value="-1" />
            </compass_settings>
            <onscreen_settings>
                <property name="sprite_name" value="ui_game_symbol_enemy_blip" />
                <property name="color" value="255,50,50,255" />
                <property name="offset" value="0,2.2,0" />
                <property name="has_pulse" value="true" />
                <property name="min_distance" value="1" />
                <property name="max_distance" value="150" />
                <property name="text_type" value="Distance" />
                <property name="font_size" value="20" />
                <property name="font_color" value="255,200,200,255" />
                <property name="sprite_size" value="32" />
                <property name="show_offscreen" value="true" />
            </onscreen_settings>
        </nav_object_class>
    </append>

    <!-- 特殊僵尸 (爆破/尖叫/辐射) 橙色 -->
    <append xpath="/nav_object_classes">
        <nav_object_class name="RadarSpecial">
            <map_settings>
                <property name="sprite_name" value="ui_game_symbol_enemy_blip" />
                <property name="min_distance" value="0" />
                <property name="max_distance" value="-1" />
                <property name="color" value="255,165,0,255" />
                <property name="has_pulse" value="true" />
            </map_settings>
            <compass_settings>
                <property name="sprite_name" value="ui_game_symbol_zombie" />
                <property name="color" value="255,165,0,255" />
                <property name="has_pulse" value="true" />
                <property name="icon_clamped" value="true" />
                <property name="min_distance" value="0" />
                <property name="max_distance" value="-1" />
            </compass_settings>
            <onscreen_settings>
                <property name="sprite_name" value="ui_game_symbol_enemy_blip" />
                <property name="color" value="255,165,0,255" />
                <property name="offset" value="0,2.2,0" />
                <property name="has_pulse" value="true" />
                <property name="min_distance" value="1" />
                <property name="max_distance" value="200" />
                <property name="text_type" value="Distance" />
                <property name="font_size" value="22" />
                <property name="font_color" value="255,220,150,255" />
                <property name="sprite_size" value="36" />
                <property name="show_offscreen" value="true" />
            </onscreen_settings>
        </nav_object_class>
    </append>

    <!-- 友好动物 (鹿/兔子/鸡) 绿色 -->
