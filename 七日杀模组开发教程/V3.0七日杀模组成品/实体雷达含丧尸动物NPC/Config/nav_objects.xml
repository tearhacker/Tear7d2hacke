            </map_settings>
            <compass_settings>
                <property name="sprite_name" value="ui_game_symbol_tracking_deer" />
                <property name="color" value="100,255,100,255" />
                <property name="icon_clamped" value="true" />
                <property name="min_distance" value="0" />
                <property name="max_distance" value="-1" />
            </compass_settings>
            <onscreen_settings>
                <property name="sprite_name" value="ui_game_symbol_tracking_deer" />
                <property name="color" value="100,255,100,255" />
                <property name="offset" value="0,1.5,0" />
                <property name="min_distance" value="1" />
                <property name="max_distance" value="100" />
                <property name="text_type" value="Distance" />
                <property name="font_size" value="18" />
                <property name="font_color" value="200,255,200,255" />
                <property name="sprite_size" value="28" />
                <property name="show_offscreen" value="true" />
            </onscreen_settings>
        </nav_object_class>
    </append>

